# ---- Project-specific ----

# Outputs are regenerated by running the scripts.
# Comment this out if you want to commit precomputed outputs to the repo.
Output/


# ---- Byte-compiled / cached files ----
__pycache__/
*.py[cod]
*$py.class
*.so

# ---- Virtual environments ----
.venv/
venv/
env/
ENV/

# ---- Distribution / packaging ----
build/
dist/
*.egg-info/
*.egg
pip-wheel-metadata/

# ---- Jupyter / IPython ----
.ipynb_checkpoints/
*.ipynb_checkpoints

# ---- Testing & coverage ----
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/

# ---- Type checkers / linters ----
.mypy_cache/
.ruff_cache/
.pyre/

# ---- IDE / editor ----
.vscode/
.idea/
*.swp
*.swo
*~

# ---- OS junk ----
.DS_Store
Thumbs.db
desktop.ini

# ---- Logs & temp ----
*.log
*.tmp
